{
  "name": "soulbrew",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @soulbrew/pos",
    "dev:pos": "npm run dev -w @soulbrew/pos",
    "dev:cliente": "npm run dev -w @soulbrew/cliente",
    "build": "npm run build -w @soulbrew/pos && npm run build -w @soulbrew/cliente",
    "build:pos": "npm run build -w @soulbrew/pos",
    "build:cliente": "npm run build -w @soulbrew/cliente",
    "preview:pos": "npm run preview -w @soulbrew/pos",
    "preview:cliente": "npm run preview -w @soulbrew/cliente"
  }
}
