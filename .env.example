# Monorepo: cada app tiene su propio .env.local (no versionado).

# ── apps/pos/.env.local ───────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
# Webhook de n8n que atiende el chat del Asistente (página /asistente)
VITE_N8N_WEBHOOK_URL=https://tu-instancia-n8n/webhook/soulbrew-asistente
# (Opcional) Base pública para los QR de fidelización. En prod se toma del dominio;
# defínela en dev para que el QR apunte a producción y no a localhost.
VITE_PUBLIC_URL=https://soulbrew-five.vercel.app

# ── apps/cliente/.env.local ───────────────────────────────────────────────────
# VITE_SUPABASE_URL=https://your-project-ref.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-key-here
# Web Push: llave PÚBLICA VAPID (no es secreta; también va en Vercel del cliente).
# VITE_VAPID_PUBLIC_KEY=tu-llave-publica-vapid
